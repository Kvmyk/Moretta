# Moretta v0.7 — Environment Configuration
# Copy this file to .env and fill in the values

# ─── Local Model (Ollama) ───────────────────────────────────────
LOCAL_MODEL=phi4-mini              # or phi3:mini for CPU-only servers
OLLAMA_URL=http://ollama:11434

# ─── Vault Encryption ──────────────────────────────────────────
VAULT_ENCRYPTION_KEY=               # 32-64 hex characters for SQLite encryption

# ─── External AI Provider Keys (configure what you need) ───────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=                 # https://openrouter.ai — single key for 200+ models

# ─── Default Provider ──────────────────────────────────────────
DEFAULT_PROVIDER=claude             # claude | openai | gemini | openrouter | ollama
DEFAULT_AI_MODEL=claude-sonnet-4.6-20260217

# ─── Application ────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=/app/data

# ─── SSO / Keycloak ─────────────────────────────────────────────
SSO_ENABLED=true
SSO_ISSUER_URL=http://keycloak:8080/auth/realms/moretta
SSO_ALLOWED_CLIENT_IDS=moretta-frontend

# Keycloak admin bootstrap (docker-compose)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# Frontend OIDC client (build-time for Vite)
VITE_KEYCLOAK_URL=http://localhost:3000/auth
VITE_KEYCLOAK_REALM=moretta
VITE_KEYCLOAK_CLIENT_ID=moretta-frontend
