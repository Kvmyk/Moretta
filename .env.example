# Moretta — Environment Configuration
# Copy this file to .env and fill in the values

# ─── Local Model (Ollama) ───────────────────────────────────────
LOCAL_MODEL=phi4-mini              # or phi3:mini for CPU-only servers
OLLAMA_URL=http://ollama:11434

# ─── Vault Encryption ──────────────────────────────────────────
VAULT_ENCRYPTION_KEY=               # 32-character key for SQLite encryption

# ─── External AI Provider Keys (configure what you need) ───────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ─── Default Provider ──────────────────────────────────────────
DEFAULT_PROVIDER=claude             # claude | openai | gemini
DEFAULT_AI_MODEL=claude-sonnet-4.6-20260217

# ─── Application ────────────────────────────────────────────────
LOG_LEVEL=INFO
DATA_DIR=/app/data
